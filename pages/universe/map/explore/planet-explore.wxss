/**planet-explore.wxss - 3D星球探索页面样式**/
page {
  height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
  overflow: hidden;
}

.explore-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 3D星球展示区域 */
.planet-3d-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  perspective: 2000px;
  perspective-origin: center center;
  overflow: hidden;
  background: radial-gradient(ellipse at center, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
}

.planet-3d {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  transform-style: preserve-3d;
  transition: transform 0.1s ease-out;
}

/* 星球核心 */
.planet-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200rpx;
  height: 200rpx;
  margin: -100rpx 0 0 -100rpx;
  border-radius: 50%;
  transform-style: preserve-3d;
  box-shadow: 
    0 0 80rpx rgba(255, 255, 255, 0.4),
    0 0 120rpx rgba(102, 126, 234, 0.3),
    inset 0 0 60rpx rgba(255, 255, 255, 0.3),
    inset -20rpx -20rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: planetGlow 6s ease-in-out infinite;
}

/* 星球表面纹理 */
.planet-surface {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
}

.surface-texture {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(45deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
  animation: surfaceRotate 15s linear infinite;
}

.surface-texture-2 {
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.1) 0%, transparent 50%);
  animation: surfaceRotate 20s linear infinite reverse;
}

.surface-texture-3 {
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.2) 0%, transparent 50%);
  animation: surfaceRotate 25s linear infinite;
}

.surface-texture-4 {
  background: conic-gradient(from 0deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%, rgba(0, 0, 0, 0.1) 100%);
  animation: surfaceRotate 30s linear infinite reverse;
}

@keyframes planetGlow {
  0%, 100% { 
    box-shadow: 
      0 0 80rpx rgba(255, 255, 255, 0.4),
      0 0 120rpx rgba(102, 126, 234, 0.3),
      inset 0 0 60rpx rgba(255, 255, 255, 0.3),
      inset -20rpx -20rpx 40rpx rgba(0, 0, 0, 0.2);
  }
  50% { 
    box-shadow: 
      0 0 120rpx rgba(255, 255, 255, 0.6),
      0 0 180rpx rgba(102, 126, 234, 0.5),
      inset 0 0 80rpx rgba(255, 255, 255, 0.4),
      inset -20rpx -20rpx 40rpx rgba(0, 0, 0, 0.2);
  }
}

/* 星球大气层 */
.planet-atmosphere {
  position: absolute;
  top: -20rpx;
  left: -20rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
}

.atmosphere-layer {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  animation: atmospherePulse 4s ease-in-out infinite;
}

.atmosphere-1 {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation-delay: 0s;
}

.atmosphere-2 {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, transparent 80%);
  animation-delay: 1s;
}

.atmosphere-3 {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.03) 0%, transparent 90%);
  animation-delay: 2s;
}

.atmosphere-4 {
  background: radial-gradient(circle, rgba(102, 126, 234, 0.05) 0%, transparent 95%);
  animation-delay: 3s;
}

@keyframes atmospherePulse {
  0%, 100% { 
    transform: scale(1); 
    opacity: 0.3; 
  }
  50% { 
    transform: scale(1.1); 
    opacity: 0.6; 
  }
}

/* 星球光环 */
.planet-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 280rpx;
  height: 280rpx;
  margin: -140rpx 0 0 -140rpx;
  border-radius: 50%;
  transform: rotateX(60deg);
}

.ring-segment {
  position: absolute;
  width: 100%;
  height: 4rpx;
  top: 50%;
  left: 0;
  margin-top: -2rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
  animation: ringRotate 30s linear infinite;
}

.ring-1 {
  animation-delay: 0s;
}

.ring-2 {
  transform: rotateY(60deg);
  animation-delay: 10s;
}

.ring-3 {
  transform: rotateY(120deg);
  animation-delay: 20s;
}

.ring-4 {
  transform: rotateY(180deg);
  animation-delay: 30s;
  opacity: 0.5;
}

@keyframes ringRotate {
  from { transform: rotateZ(0deg); }
  to { transform: rotateZ(360deg); }
}

/* 星球emoji */
.planet-emoji {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
  z-index: 10;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.5);
}

/* 星球光晕效果 */
.planet-aura {
  position: absolute;
  top: -50rpx;
  left: -50rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
  animation: auraPulse 8s ease-in-out infinite;
  z-index: -1;
}

/* 星球轨道 */
.planet-orbit {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 400rpx;
  height: 400rpx;
  margin: -200rpx 0 0 -200rpx;
  border-radius: 50%;
  animation: orbitRotate 60s linear infinite;
}

.orbit-line {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.orbit-dots {
  position: absolute;
  width: 100%;
  height: 100%;
}

.orbit-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  top: 50%;
  left: 50%;
  margin: -4rpx 0 0 -4rpx;
  transform-origin: 0 0;
}

.orbit-dot:nth-child(1) { transform: rotate(0deg) translateX(200rpx); }
.orbit-dot:nth-child(2) { transform: rotate(60deg) translateX(200rpx); }
.orbit-dot:nth-child(3) { transform: rotate(120deg) translateX(200rpx); }
.orbit-dot:nth-child(4) { transform: rotate(180deg) translateX(200rpx); }
.orbit-dot:nth-child(5) { transform: rotate(240deg) translateX(200rpx); }
.orbit-dot:nth-child(6) { transform: rotate(300deg) translateX(200rpx); }

@keyframes orbitRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes auraPulse {
  0%, 100% { 
    transform: scale(1); 
    opacity: 0.3; 
  }
  50% { 
    transform: scale(1.2); 
    opacity: 0.6; 
  }
}

/* 星空背景 */
.starfield {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.star {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  animation: starTwinkle 3s ease-in-out infinite;
}

.star:nth-child(odd) {
  animation-delay: 0s;
}

.star:nth-child(even) {
  animation-delay: 1.5s;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* 星球信息面板 */
.planet-info-panel {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 20rpx;
  padding: 20rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.planet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.planet-desc {
  font-size: 24rpx;
  color: #a0aec0;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.planet-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #a0aec0;
}

/* 控制面板 */
.control-panel {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.9);
  border-radius: 24rpx;
  padding: 24rpx;
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.control-section {
  margin-bottom: 20rpx;
}

.control-section:last-child {
  margin-bottom: 0;
}

.control-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.control-buttons {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.control-btn {
  flex: 1;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #fff;
  transition: all 0.3s ease;
  backdrop-filter: blur(5px);
}

.control-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
}

.control-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  font-size: 24rpx;
}

/* 滑块控制 */
.slider-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.slider-label {
  font-size: 22rpx;
  color: #a0aec0;
  min-width: 120rpx;
}

.rotation-slider {
  flex: 1;
}

.scale-display {
  text-align: center;
  margin-top: 8rpx;
}

.scale-text {
  font-size: 20rpx;
  color: #667eea;
  font-weight: 500;
}

/* 梦境面板 */
.dreams-panel {
  position: absolute;
  top: 200rpx;
  right: 20rpx;
  width: 300rpx;
  max-height: 400rpx;
  background: rgba(0, 0, 0, 0.8);
  border-radius: 20rpx;
  padding: 20rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.panel-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.dreams-scroll {
  max-height: 300rpx;
}

.dream-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.dream-item:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

.dream-date {
  font-size: 20rpx;
  color: #a0aec0;
  margin-bottom: 8rpx;
}

.dream-preview {
  font-size: 22rpx;
  color: #fff;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dream-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.dream-tag {
  font-size: 18rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.2);
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

/* 操作提示 */
.operation-hints {
  position: absolute;
  top: 50%;
  left: 20rpx;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hint-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 20rpx;
  padding: 12rpx 16rpx;
  backdrop-filter: blur(5px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.hint-icon {
  font-size: 24rpx;
}

.hint-text {
  font-size: 20rpx;
  color: #a0aec0;
}
