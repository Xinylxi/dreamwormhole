<!--test.wxml - AI分析测试页面-->
<navigation-bar title="AI分析测试" back="{{true}}" color="#fff" background="linear-gradient(135deg, #667eea 0%, #764ba2 100%)" bind:back="onBack"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="test-container">
    <view class="test-title">AI分析功能测试</view>
    
    <view class="test-buttons">
      <button class="test-btn" bindtap="testCloud" disabled="{{isLoading}}">
        <text class="btn-icon">☁️</text>
        <text>测试云开发</text>
      </button>
      
      <button class="test-btn" bindtap="testCozeAPI" disabled="{{isLoading}}">
        <text class="btn-icon">🤖</text>
        <text>测试 Coze API</text>
      </button>
      
      <button class="test-btn" bindtap="testMockAnalyze" disabled="{{isLoading}}">
        <text class="btn-icon">🎭</text>
        <text>测试模拟分析</text>
      </button>
      
      <button class="test-btn" bindtap="testNetwork" disabled="{{isLoading}}">
        <text class="btn-icon">🌐</text>
        <text>测试网络连接</text>
      </button>
      
      <button class="test-btn clear-btn" bindtap="clearResult" disabled="{{isLoading}}">
        <text class="btn-icon">🗑️</text>
        <text>清空结果</text>
      </button>
    </view>
    
    <view class="test-result" wx:if="{{testResult}}">
      <view class="result-title">测试结果：</view>
      <text class="result-text">{{testResult}}</text>
    </view>
    
    <view class="test-tips">
      <view class="tips-title">测试说明：</view>
      <view class="tips-item">1. 点击"测试云开发"检查数据库连接和读写功能</view>
      <view class="tips-item">2. 点击"测试 Coze API"检查真实AI分析功能</view>
      <view class="tips-item">3. 点击"测试模拟分析"检查本地分析功能</view>
      <view class="tips-item">4. 点击"测试网络连接"检查API连通性</view>
      <view class="tips-item">5. 查看控制台日志获取详细信息</view>
    </view>
  </view>
</scroll-view>
