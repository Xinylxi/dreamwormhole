<!--api-test.wxml - API测试页面-->
<navigation-bar title="API测试" back="{{true}}" color="#fff" background="linear-gradient(135deg, #667eea 0%, #764ba2 100%)" bind:back="onBack"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="test-container">
    <view class="test-title">API 弃用警告测试</view>
    
    <view class="test-buttons">
      <button class="test-btn" bindtap="testNewAPI" disabled="{{isLoading}}">
        <text class="btn-icon">🔧</text>
        <text>测试新API</text>
      </button>
      
      <button class="test-btn clear-btn" bindtap="clearResult" disabled="{{isLoading}}">
        <text class="btn-icon">🗑️</text>
        <text>清空结果</text>
      </button>
    </view>
    
    <view class="test-result" wx:if="{{testResult}}">
      <view class="result-title">测试结果：</view>
      <text class="result-text">{{testResult}}</text>
    </view>
    
    <view class="test-tips">
      <view class="tips-title">解决弃用警告的方法：</view>
      <view class="tips-item">1. 重新编译小程序（清除缓存）</view>
      <view class="tips-item">2. 重启微信开发者工具</view>
      <view class="tips-item">3. 检查控制台是否还有警告</view>
      <view class="tips-item">4. 如果仍有警告，可能是工具缓存问题</view>
    </view>
  </view>
</scroll-view>
