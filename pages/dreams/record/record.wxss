/**
 * 梦境记录页面 - 修复版样式
 * 适配微信小程序 WXSS 规范，无语法错误，兼容真机
 */

/* 全局页面 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

/* 欢迎区域 */
.hero-section {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  background: radial-gradient(ellipse at center, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(102, 126, 234, 0.5);
}

.hero-subtitle {
  font-size: 28rpx;
  color: #a0aec0;
}

/* 记录卡片 */
.record-card {
  margin: 0 30rpx 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 40rpx;
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.record-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.record-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.record-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 语音按钮 */
.primary-action {
  margin: 30rpx 0;
  text-align: center;
}

.voice-btn-primary {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 60rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.voice-btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
}

.voice-btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.voice-btn-primary:active::before {
  left: 100%;
}

.voice-btn-primary.pressed {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
  filter: brightness(1.05);
}

.voice-icon-large {
  font-size: 40rpx;
  animation: voicePulse 2s ease-in-out infinite;
  flex-shrink: 0;
}

.voice-labels {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.2;
  max-width: 80%;
}

.voice-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5rpx;
}

.voice-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

/* 录音浮层 */
.record-overlay {
  position: fixed;
  left: 50%;
  bottom: 22%;
  transform: translateX(-50%);
  padding: 20rpx 28rpx;
  background: rgba(0,0,0,0.75);
  color: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.25);
}

.record-overlay .overlay-icon {
  font-size: 32rpx;
}

.record-overlay .overlay-text {
  font-size: 28rpx;
}

.record-overlay.danger {
  background: rgba(220, 38, 38, 0.9);
}

/* 录音中状态 */
.recording-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.3);
}

.recording-indicator {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.recording-dot {
  width: 20rpx;
  height: 20rpx;
  background: #fff;
  border-radius: 50%;
  animation: recordingBlink 1s ease-in-out infinite;
}

.recording-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.stop-recording-btn {
  width: 200rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #fff;
  transition: all 0.3s ease;
}

.stop-recording-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 录音完成 */
.recording-complete {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(78, 205, 196, 0.3);
}

.recording-info {
  text-align: center;
}

.recording-duration {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.recording-controls {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.play-btn, .delete-recording-btn {
  flex: 1;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #fff;
  transition: all 0.3s ease;
  border: none;
}

.play-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.play-btn.playing {
  background: rgba(255, 255, 255, 0.3);
}

.delete-recording-btn {
  background: rgba(255, 107, 107, 0.3);
  border: 2rpx solid rgba(255, 107, 107, 0.5);
}

.play-btn:active, .delete-recording-btn:active {
  transform: scale(0.95);
}

/* 顶部工具栏 */
.toolbar-top {
  display: flex;
  gap: 15rpx;
  margin: 20rpx 0;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
}

.toolbar-btn {
  flex: 1;
  height: 70rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  transition: all 0.3s ease;
  padding: 0 10rpx;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
  overflow: hidden;
}

.toolbar-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

.toolbar-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.toolbar-btn .btn-icon {
  font-size: 24rpx;
  position: absolute;
  left: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  flex-shrink: 0;
}

.toolbar-btn .btn-text {
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  text-align: center;
  line-height: normal;
}

/* 输入区域 */
.input-area {
  position: relative;
  margin-bottom: 30rpx;
}

.dream-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
  box-sizing: border-box;
  backdrop-filter: blur(10px);
}

.dream-textarea:focus {
  border-color: #667eea;
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 0 20rpx rgba(102, 126, 234, 0.3);
}

.char-count {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  font-size: 24rpx;
  color: #a0aec0;
  background: rgba(0, 0, 0, 0.5);
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  backdrop-filter: blur(5px);
}

/* 情绪标签 */
.tags-preview {
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tag-name {
  width: 120rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.tag-bar {
  flex: 1;
  height: 12rpx;
  background: #e2e8f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.tag-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.tag-value {
  width: 80rpx;
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 分析结果 */
.analysis-result {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.result-planet {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.planet-emoji {
  font-size: 40rpx;
}

.planet-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.result-tag {
  padding: 8rpx 16rpx;
  background: rgba(102, 126, 234, 0.3);
  border: 1rpx solid rgba(102, 126, 234, 0.5);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.result-interpretation {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
}

/* 最近梦境 */
.recent-section {
  margin: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.section-link-btn {
  font-size: 26rpx;
  color: #667eea;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background: transparent;
  border: none;
}

.section-link-btn:active {
  background: rgba(102, 126, 234, 0.1);
  transform: scale(0.95);
  color: #5568d3;
}

.dream-list {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.dream-item {
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.02);
  transition: all 0.3s ease;
}

.dream-item:last-child {
  border-bottom: none;
}

.dream-item:active {
  background: rgba(255, 255, 255, 0.05);
  transform: scale(0.98);
}

.dream-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dream-date, .dream-time {
  font-size: 24rpx;
  color: #a0aec0;
  font-weight: 500;
}

.dream-emotion {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.emotion-icon {
  font-size: 24rpx;
}

.dream-preview {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dream-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.dream-tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 40rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #a0aec0;
}

/* 互动功能 */
.interaction-section {
  margin: 0 30rpx 40rpx;
}

.interaction-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.interaction-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.interaction-content {
  flex: 1;
}

.interaction-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.interaction-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
}

.interaction-arrow {
  font-size: 36rpx;
  color: #fff;
  margin-left: 16rpx;
}

.preview-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.preview-more {
  color: #667eea;
  font-weight: 500;
}


/* Coze故事相关样式 - 沉浸式平行宇宙风格 */

/* 故事容器 - 渐变背景 */
.coze-story-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 30rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.35);
  position: relative;
  overflow: hidden;
}

/* 添加星空背景效果 */
.coze-story-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(2px 2px at 20px 30px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 40px 70px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 50px 160px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 90px 40px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 130px 80px, #ffffff, rgba(0,0,0,0));
  background-repeat: repeat;
  background-size: 200px 200px;
  opacity: 0.1;
  pointer-events: none;
}

/* 故事头部 */
.coze-story-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.coze-story-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.coze-story-icon {
  font-size: 44rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.05);
  }
}

.coze-story-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.coze-story-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.coze-story-close:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.close-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 故事内容容器 */
.coze-story-content {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 1;
}

/* 轮次徽章 */
.round-badge {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.round-text {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(240, 147, 251, 0.3);
}

/* 情绪指数显示 */
.emotion-score-display {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.emotion-score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  text-align: center;
}

.emotion-score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.emotion-score-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.emotion-score-fill {
  height: 100%;
  background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

/* 故事文本 */
.story-text {
  font-size: 30rpx;
  line-height: 1.9;
  color: #ffffff;
  word-wrap: break-word;
  text-align: justify;
  position: relative;
  z-index: 1;
}

/* 关键词显示 */
.keywords-display {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.keywords-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-right: 12rpx;
  font-weight: bold;
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

/* 加载状态样式 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  margin: 20rpx 0;
  position: relative;
  z-index: 1;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  border-top-color: #ffffff;
  animation: spin 0.8s ease-in-out infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
  opacity: 0.95;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 选项容器 */
.coze-options-container {
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.options-title {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 28rpx;
  text-align: center;
  opacity: 0.95;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ABCD按钮容器 */
.abcd-buttons {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

/* ABCD按钮样式 - 沉浸式风格 */
.abcd-btn {
  flex: 1;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 20rpx;
  font-size: 42rpx;
  font-weight: bold;
  color: #667eea;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 150rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.abcd-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(102, 126, 234, 0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.abcd-btn:active::before {
  width: 300rpx;
  height: 300rpx;
}

.abcd-btn-hover {
  background: #ffffff;
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.25);
}

/* 选项描述区域 */
.options-descriptions {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.option-desc-item {
  display: flex;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  align-items: flex-start;
}

.option-desc-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.option-desc-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  min-width: 60rpx;
  margin-right: 16rpx;
  opacity: 0.95;
  flex-shrink: 0;
}

.option-desc-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  flex: 1;
  line-height: 1.7;
  word-wrap: break-word;
}

/* 底部提示 */
.coze-story-footer {
  margin-top: 28rpx;
  text-align: center;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  z-index: 1;
}

.footer-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  font-style: italic;
  letter-spacing: 1rpx;
}

/* 响应式优化 */
@media (max-width: 375px) {
  .coze-story-section {
    padding: 24rpx;
    margin: 24rpx 16rpx;
  }
  
  .coze-story-title {
    font-size: 36rpx;
  }
  
  .abcd-btn {
    height: 90rpx;
    font-size: 38rpx;
    max-width: 130rpx;
  }
  
  .option-desc-label {
    font-size: 30rpx;
    min-width: 55rpx;
  }
  
  .option-desc-text {
    font-size: 26rpx;
  }
}




/* 动画 */
@keyframes voicePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

@keyframes recordingBlink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0.3; }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}